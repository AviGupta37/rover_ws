<?xml version="1.0"?>
<robot name="rover_ackermann">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <box size="1.0 0.5 0.1"/> </geometry>
    </visual>
  </link>

  <link name="serial_manipulator_base_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.5"/>
      </geometry>
    </visual>
  </link>

  <joint name="serial_manipulator_base_base_link_joint" type="revolute">
    <parent link="base_link"/>
    <child link="serial_manipulator_base_link"/>
    <origin xyz="0.1 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.57" effort="1000" velocity="1.0"/>
  </joint>

  <link name="serial_manipulator_hand_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.5"/>
      </geometry>
    </visual>
  </link>

  <joint name="serial_manipulator_base_hand_link_joint" type="revolute">
    <parent link="serial_manipulator_base_link"/>
    <child link="serial_manipulator_hand_link"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0.577 0.577 0.577"/>
    <limit lower="-1.57" upper="1.57" effort="1000" velocity="1.0"/>
  </joint>

</robot>
